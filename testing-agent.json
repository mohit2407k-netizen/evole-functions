{
  "endpoints": [
    {
      "method": "POST",
      "path": "/onboardUser",
      "type": "onCall",
      "description": "Onboard a new user (requires Firebase Auth token)",
      "sampleBody": {
        "data": {
          "name": "John Doe",
          "age": 21,
          "gender": "Male",
          "phone": "9876543210",
          "currentStatus": "Student",
          "qualification": "B.Tech",
          "stream": "Computer Science",
          "yearOfCompletion": 2025
        }
      }
    },
    {
      "method": "POST",
      "path": "/createCounsellorRequest",
      "type": "onCall",
      "description": "Create a counsellor onboarding request (requires Firebase Auth token)",
      "sampleBody": {
        "data": {
          "basicDetail": {
            "name": "Jane Smith",
            "phone": "9123456789"
          },
          "qualification": "M.A. Psychology",
          "counsellingDomain": ["Career", "Mental Health"],
          "availability": {
            "monday": ["10:00", "14:00"]
          },
          "approach": "CBT"
        }
      }
    },
    {
      "method": "POST",
      "path": "/approveCounsellorRequest",
      "type": "onRequest",
      "description": "Admin approves a pending counsellor request",
      "sampleBody": {
        "adminUid": "admin_uid_here",
        "targetUid": "counsellor_uid_here"
      }
    },
    {
      "method": "POST",
      "path": "/rejectRequest",
      "type": "onRequest",
      "description": "Admin rejects a pending counsellor request",
      "sampleBody": {
        "adminUid": "admin_uid_here",
        "targetUid": "counsellor_uid_here"
      }
    },
    {
      "method": "POST",
      "path": "/submitCounsellingForms",
      "type": "onRequest",
      "description": "User submits counselling forms (quick or deep mode)",
      "sampleBody": {
        "uid": "user_uid_here",
        "mode": "quick",
        "forms": {}
      }
    },
    {
      "method": "POST",
      "path": "/submitSessionRequest",
      "type": "onRequest",
      "description": "User submits a session request with a counsellor",
      "sampleBody": {
        "userID": "user_uid_here",
        "counsellorID": "counsellor_uid_here"
      }
    },
    {
      "method": "POST",
      "path": "/scheduleSession",
      "type": "onRequest",
      "description": "Counsellor schedules or updates session status",
      "sampleBody": {
        "counsellorUID": "counsellor_uid_here",
        "sessionID": "session_id_here",
        "status": "scheduled",
        "scheduledAt": "2026-06-10T10:00:00Z"
      }
    }
  ]
}
